{
  "multipart": [
    { "when": { "active": "false", "facing": "north" }, "apply": { "model": "xuanhuan_earth:block/alchemy_furnace" } },
    { "when": { "active": "false", "facing": "east" }, "apply": { "model": "xuanhuan_earth:block/alchemy_furnace", "y": 90 } },
    { "when": { "active": "false", "facing": "south" }, "apply": { "model": "xuanhuan_earth:block/alchemy_furnace", "y": 180 } },
    { "when": { "active": "false", "facing": "west" }, "apply": { "model": "xuanhuan_earth:block/alchemy_furnace", "y": 270 } },
    { "when": { "active": "true", "facing": "north" }, "apply": { "model": "xuanhuan_earth:block/alchemy_furnace_active" } },
    { "when": { "active": "true", "facing": "east" }, "apply": { "model": "xuanhuan_earth:block/alchemy_furnace_active", "y": 90 } },
    { "when": { "active": "true", "facing": "south" }, "apply": { "model": "xuanhuan_earth:block/alchemy_furnace_active", "y": 180 } },
    { "when": { "active": "true", "facing": "west" }, "apply": { "model": "xuanhuan_earth:block/alchemy_furnace_active", "y": 270 } }
  ]
}
